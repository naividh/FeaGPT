{
      "hosting": {
          "public": "frontend/build",
              "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
                  "rewrites": [
                        {
                                "source": "/api/**",
                                        "run": {
                                                  "serviceId": "feagpt-api",
                                                            "region": "us-central1"
                                                                    }
                                                                          },
                                                                                {
                                                                                        "source": "**",
                                                                                                "destination": "/index.html"
                                                                                                      }
                                                                                                          ]
                                                                                                            },
                                                                                                              "functions": {
                                                                                                                  "source": "functions",
                                                                                                                      "runtime": "python311",
                                                                                                                          "codebase": "feagpt-functions"
                                                                                                                            },
                                                                                                                              "firestore": {
                                                                                                                                  "rules": "firestore.rules",
                                                                                                                                      "indexes": "firestore.indexes.json"
                                                                                                                                        },
                                                                                                                                          "storage": {
                                                                                                                                              "rules": "storage.rules"
                                                                                                                                                },
                                                                                                                                                  "emulators": {
                                                                                                                                                      "hosting": { "port": 5000 },
                                                                                                                                                          "functions": { "port": 5001 },
                                                                                                                                                              "firestore": { "port": 8080 },
                                                                                                                                                                  "storage": { "port": 9199 },
                                                                                                                                                                      "ui": { "enabled": true, "port": 4000 }
                                                                                                                                                                        }
                                                                                                                                                                        }
}