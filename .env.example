# FeaGPT Environment Variables
# Copy to .env and fill in your values

# Required: Gemini API Key for LLM planning
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud (for deployment)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Firebase (optional, for web interface)
FIREBASE_TOKEN=

# Application settings
FEAGPT_ENV=development
FEAGPT_CONFIG=config.yaml
FEAGPT_LOG_LEVEL=INFO

# Batch processing
FEAGPT_MAX_WORKERS=10
FEAGPT_MEMORY_PER_CASE_MB=512