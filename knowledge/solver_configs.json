{
      "static-linear": {
          "description": "Linear static analysis for stress and displacement",
              "keywords": ["static", "linear", "stress", "displacement", "structural"],
                  "template": {
                        "analysis_type": "static",
                              "steps": [
                                      {"name": "static_step", "type": "*STATIC", "increments": "1.0, 1.0, 0.01, 1.0"}
                                            ],
                                                  "output": ["S", "U", "RF"],
                                                        "solver_settings": {
                                                                "max_iterations": 100,
                                                                        "convergence": 1e-6
                                                                              }
                                                                                  }
                                                                                    },
                                                                                      "frequency": {
                                                                                          "description": "Natural frequency and modal analysis",
                                                                                              "keywords": ["modal", "frequency", "eigenvalue", "vibration", "natural"],
                                                                                                  "template": {
                                                                                                        "analysis_type": "frequency",
                                                                                                              "steps": [
                                                                                                                      {"name": "freq_step", "type": "*FREQUENCY", "num_modes": 10, "solver": "LANCZOS"}
                                                                                                                            ],
                                                                                                                                  "output": ["S", "U"]
                                                                                                                        }
                                                                                                                          },
                                                                                                                            "prestressed-modal": {
                                                                                                                                    "description": "Prestressed modal analysis (static preload then frequency extraction)",
                                                                                                                                        "keywords": ["prestress", "rotating", "centrifugal", "rpm", "cyclic", "turbocharger"],
                                                                                                                                            "template": {
                                                                                                                                                  "analysis_type": "prestressed_modal",
                                                                                                                                                        "steps": [
                                                                                                                                                                    {"name": "static_preload", "type": "*STATIC", "increments": "1.0, 1.0, 0.01, 1.0"        {"name": "frequency_step", "type": "*FREQUENCY", "num_modes": 6, "solver": "LANCZOS"}
                                                                                                                                                                          ],
                                                                                                                                                                                "output": ["S", "U"],
                                                                                                                                                                                      "special_cards": ["*CYCLIC SYMMETRY MODEL", "*DLOAD,OP=NEW"]
                                                                                                                                                                        }
                                                                                                                                                                          },
                                                                                                                                                                            "multi-step-load-spectrum": {
                                                                                                                                                                                "description": "Multi-step load spectrum for fatigue assessment of flight structures",
                                                                                                                                                                                    "keywords": ["fatigue", "load spectrum", "flight", "cyclic", "maneuver", "gust", "landing"],
                                                                                                                                                                                        "template": {
                                                                                                                                                                                                  "analysis_type": "static",
                                                                                                                                                                                                        "steps": [
                                                                                                                                                                                                                {"name": "cruise", "type": "*STATIC", "load_factor": 1.0, "description": "1.0g cruise"},
                                                                                                                                                                                                                        {"name": "maneuver", "type": "*STATIC", "load_factor": 2.5, "description": "2.5g pull-up"},
                                                                                                                                                                                                                                {"name": "gust", "type": "*STATIC", "load_factor": 1.8, "description": "1.8g gust"},
                                                                                                                                                                                                                                        {"name": "landing", "type": "*STATIC", "load_factor": 3.0, "description": "3.0g landing"},
                                                                                                                                                                                                                                                {"name": "gag_1", "type": "*STATIC", "load_factor": 0.5, "description": "GAG cycle 1"},
                                                                                                                                                                                                                                                        {"name": "gag_2", "type": "*STATIC", "load_factor": 1.0, "description": "GAG cycle 2"},
                                                                                                                                                                                                                                                                {"name": "gag_3", "type": "*STATIC", "load_factor": 1.5, "description": "GAG cycle 3"},
                                                                                                                                                                                                                                                                        {"name": "gag_4", "type": "*STATIC", "load_factor": 0.5, "description": "GAG cycle 4"}
                                                                                                                                                                                                                                                                              ],
                                                                                                                                                                                                                                                                                    "output": ["S", "U", "RF"]
                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                          },
                                                                                                                                                                                                                                                                                            "buckling": {
                                                                                                                                                                                                                                                                                                    "description": "Linear buckling analysis for critical load estimation",
                                                                                                                                                                                                                                                                                                        "keywords": ["buckling", "stability", "critical load", "eigenvalue"    "template": {
                                                                                                                                                                                                                                                                                                                  "analysis_type": "buckling",
                                                                                                                                                                                                                                                                                                                        "steps": [
                                                                                                                                                                                                                                                                                                                                    {"name": "static_preload", "type": "*STATIC", "increments": "1.0, 1.0, 0.01, 1.0"},
                                                                                                                                                                                                                                                                                                                                            {"name": "buckle_step", "type": "*BUCKLE", "num_modes": 5}
                                                                                                                                                                                                                                                                                                                        ],
                                                                                                                                                                                                                                                                                                                              "output": ["S", "U"]
                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                  "nonlinear-static": {
                                                                                                                                                                                                                                                                                                                                        "description": "Geometrically nonlinear static analysis with NLGEOM",
                                                                                                                                                                                                                                                                                                                                            "keywords": ["nonlinear", "large deformation", "NLGEOM", "plasticity"],
                                                                                                                                                                                                                                                                                                                                                "template": {
                                                                                                                                                                                                                                                                                                                                                      "analysis_type": "static_nonlinear",
                                                                                                                                                                                                                                                                                                                                                            "steps": [
                                                                                                                                                                                                                                                                                                                                                                    {"name": "nlstatic", "type": "*STATIC,NLGEOM", "increments": "0.1, 1.0, 0.001, 0.5"}
                                                                                                                                                                                                                                                                                                                                                                          ],
                                                                                                                                                                                                                                                                                                                                                                                "output": ["S", "U", "PEEQ", "RF"],
                                                                                                                                                                                                                                                                                                                                                                                      "solver_settings": {
                                                                                                                                                                                                                                                                                                                                                                                                "max_iterations": 200,
                                                                                                                                                                                                                                                                                                                                                                                                        "convergence": 1e-5
                                                                                                                                                                                                                                                                                                                                                                                      }
                                                                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                                                                                                                                                              "thermal-stress": {
                                                                                                                                                                                                                                                                                                                                                                                                    "description": "Coupled thermal-structural analysis",
                                                                                                                                                                                                                                                                                                                                                                                                        "keywords": ["thermal", "temperature", "heat", "thermal stress", "coupled"],
                                                                                                                                                                                                                                                                                                                                                                                                            "template": {
                                                                                                                                                                                                                                                                                                                                                                                                                      "analysis_type": "coupled_thermal",
                                                                                                                                                                                                                                                                                                                                                                                                                            "steps": [
                                                                                                                                                                                                                                                                                                                                                                                                                                        {"name": "heat_transfer", "type": "*HEAT TRANSFER, STEADY STATE"},
                                                                                                                                                                                                                                                                                                                                                                                                                                                {"name": "thermal_stress", "type": "*STATIC", "uses_temperature": true}
                                                                                                                                                                                                                                                                                                                                                                                                                                                      ],
                                                                                                                                                                                                                                                                                                                                                                                                                                                            "output": ["S", "U", "NT", "HFL"]
                                                                                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                                                                                                                                                      }
                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                        }
                                                                                                                                                        ]
                                                                                                                            }
}